    public async Task<{{ pk_type }}> CreateAsync(
        Create{{ entity_name }}Request r, CancellationToken ct = default)
    {
        var entity = new {{ entity_name }}
        {
            {{~ for col in form_columns ~}}
            {{~ # En Create: asignación directa siempre.                          ~}}
            {{~ # El DTO tiene el tipo exacto (T o T?) — no necesita .Value       ~}}
            {{~ # Los campos NOT NULL vienen como T en el DTO de Create           ~}}
            {{~ # Los campos NULL    vienen como T? en el DTO de Create           ~}}
            {{ col.property_name }} = r.{{ col.property_name }},
            {{~ end ~}}
            {{~ if has_creado_en ~}}
            CreadoEn    = DateTime.UtcNow,
            {{~ end ~}}
            {{~ if has_creado_por ~}}
            CreadoPor   = "system",
            {{~ end ~}}
        };

        _ctx.Set<{{ entity_name }}>().Add(entity);
