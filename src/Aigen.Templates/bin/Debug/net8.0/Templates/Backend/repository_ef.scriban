    {{ if use_pagination }}
    // ── GetPaged ──────────────────────────────────────────────
    public async Task<{{ entity_name }}PagedResponse> GetPagedAsync(
        int page, int pageSize, CancellationToken ct = default)
    {
        var query = BaseQuery();
        var total = await query.CountAsync(ct);

        var items = await query
            .OrderBy(e => e.{{ pk_name }})
            .Skip((page - 1) * pageSize)
            .Take(pageSize)
            .ToListAsync(ct);

        return new(items.Select(MapToDto).ToList(), total, page, pageSize);
    }
    {{ else }}
    // ── GetAll ────────────────────────────────────────────────
    public async Task<List<{{ entity_name }}Dto>> GetAllAsync(
