            .FirstOrDefaultAsync(e => e.{{ pk_name }} == id, ct)
            ?? throw new KeyNotFoundException(
                $"{{ entity_name }} {id} no encontrado.");

        entity.Eliminado = true;
        {{~ if has_modificado_en ~}}entity.ModificadoEn  = DateTime.UtcNow;{{~ end ~}}
        {{~ if has_modificado_por ~}}entity.ModificadoPor = "system";{{~ end ~}}
        await _ctx.SaveChangesAsync(ct);
    }
