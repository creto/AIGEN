    // ── Update ────────────────────────────────────────────────
    // NOTA: form_columns excluye PK e identity — la PK no se puede cambiar
    public async Task UpdateAsync(
        {{ pk_type }} id, Update{{ entity_name }}Request r, CancellationToken ct = default)
    {
        var entity = await _ctx.Set<{{ entity_name }}>()
            .FirstOrDefaultAsync(e => e.{{ pk_name }} == id, ct)
            ?? throw new KeyNotFoundException(
                $"{{ entity_name }} {id} no encontrado.");

        {{~ for col in form_columns ~}}
        {{~ # Lógica de asignación en Update por tipo:                            ~}}
        {{~ #                                                                     ~}}
        {{~ #  string / byte[]  → reference type                                 ~}}
        {{~ #    El Request DTO lo tiene como string? (nullable ref)             ~}}
        {{~ #    Comparar con null, asignar directo                              ~}}
        {{~ #                                                                     ~}}
        {{~ #  value type NOT NULL (is_nullable=false, is_value_type=true)        ~}}
        {{~ #    El Request DTO lo tiene como T? para hacer el campo opcional    ~}}
        {{~ #    Usar .HasValue para verificar y .Value para extraer             ~}}
        {{~ #                                                                     ~}}
        {{~ #  value type NULLABLE (is_nullable=true, is_value_type=true)         ~}}
        {{~ #    El Request DTO lo tiene como T?                                  ~}}
        {{~ #    Verificar HasValue; si tiene valor asignar .Value               ~}}
        {{~ #    Si no tiene valor (null), dejar el campo como estaba            ~}}
        {{~ # ─────────────────────────────────────────────────────────────────── ~}}
        {{~ if !col.is_value_type ~}}
        if (r.{{ col.property_name }} != null)
            entity.{{ col.property_name }} = r.{{ col.property_name }};
        {{~ else ~}}
        if (r.{{ col.property_name }}.HasValue)
            entity.{{ col.property_name }} = r.{{ col.property_name }}.Value;
        {{~ end ~}}
        {{~ end ~}}
        {{~ if has_modificado_en ~}}
        entity.ModificadoEn  = DateTime.UtcNow;
        {{~ end ~}}
        {{~ if has_modificado_por ~}}
        entity.ModificadoPor = "system";
        {{~ end ~}}

        await _ctx.SaveChangesAsync(ct);
    }

    {{~ if has_eliminado_column ~}}
    // ── SoftDelete ────────────────────────────────────────────
    public async Task SoftDeleteAsync(
