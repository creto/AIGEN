        builder.HasIndex({{ for col in idx.columns }}e => e.{{ col }}{{ if !for.last }}, {{ end }}{{ end }})
               .HasDatabaseName("{{ idx.index_name }}")
               {{ if idx.is_unique }}.IsUnique(){{ end }};
        {{ end ~}}
        {{ end }}
    }
