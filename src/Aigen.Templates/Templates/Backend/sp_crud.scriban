-- ── sp_GetPaged_{{ table_name }} ──────────────────────────────────────
IF OBJECT_ID('{{ db_schema }}.sp_GetPaged_{{ table_name }}', 'P') IS NOT NULL
    DROP PROCEDURE [{{ db_schema }}].[sp_GetPaged_{{ table_name }}]
GO

CREATE PROCEDURE [{{ db_schema }}].[sp_GetPaged_{{ table_name }}]
    @Page     INT = 1,
    @PageSize INT = 20
AS
BEGIN
    SET NOCOUNT ON;
    SELECT *
    FROM   [{{ db_schema }}].[{{ table_name }}]
    {{ if has_estado }}WHERE [{{ estado_property_name }}] = 1{{ end }}
    ORDER  BY [{{ pk_column_name }}]
    OFFSET (@Page - 1) * @PageSize ROWS
    FETCH  NEXT @PageSize ROWS ONLY;

    SELECT COUNT(*)
    FROM   [{{ db_schema }}].[{{ table_name }}]
    {{ if has_estado }}WHERE [{{ estado_property_name }}] = 1{{ end }};
END
GO
