CREATE PROCEDURE [{{ db_schema }}].[sp_Update_{{ table_name }}]
    @{{ pk_name }} {{ pk_sql_type }},
{{~ for col in form_columns ~}}
    @{{ col.property_name }} {{ col.sql_type }}{{ if col.has_max_length }}({{ col.max_length }}){{ end }} = NULL{{ if !for.last }},{{ end }}
{{~ end ~}}
AS
BEGIN
    SET NOCOUNT ON;
    UPDATE [{{ db_schema }}].[{{ table_name }}]
    SET
{{~ for col in form_columns ~}}
        [{{ col.column_name }}] = ISNULL(@{{ col.property_name }}, [{{ col.column_name }}]){{ if !for.last }},{{ end }}
{{~ end ~}}
    WHERE [{{ pk_column_name }}] = @{{ pk_name }};
END
GO

-- ── sp_Delete_{{ table_name }} ────────────────────────────────────────
IF OBJECT_ID('{{ db_schema }}.sp_Delete_{{ table_name }}', 'P') IS NOT NULL
    DROP PROCEDURE [{{ db_schema }}].[sp_Delete_{{ table_name }}]
GO

CREATE PROCEDURE [{{ db_schema }}].[sp_Delete_{{ table_name }}]
    @{{ pk_name }} {{ pk_sql_type }}
AS
BEGIN
    SET NOCOUNT ON;
    {{ if has_eliminado_column }}
    UPDATE [{{ db_schema }}].[{{ table_name }}] SET Eliminado = 1 WHERE [{{ pk_column_name }}] = @{{ pk_name }};
    {{ else if has_estado }}
    UPDATE [{{ db_schema }}].[{{ table_name }}] SET [{{ estado_property_name }}] = 0 WHERE [{{ pk_column_name }}] = @{{ pk_name }};
    {{ else }}
    DELETE FROM [{{ db_schema }}].[{{ table_name }}] WHERE [{{ pk_column_name }}] = @{{ pk_name }};
    {{ end }}
END
GO

