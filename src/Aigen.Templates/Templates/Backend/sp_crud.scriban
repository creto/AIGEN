GO

CREATE PROCEDURE [{{ db_schema }}].[sp_Insert_{{ table_name }}]
{{~ param_idx = 0 ~}}
{{~ for col in form_columns ~}}
{{~ if !col.is_identity ~}}
    @{{ col.property_name }} {{ col.sql_type }}{{ if col.has_max_length }}({{ col.max_length }}){{ end }}{{ if col.is_nullable }} = NULL{{ end }}{{ if param_idx < (form_columns | array.size) - 1 }},{{ end }}
{{~ param_idx = param_idx + 1 ~}}
{{~ end ~}}
{{~ end ~}}
AS
BEGIN
    SET NOCOUNT ON;
    INSERT INTO [{{ db_schema }}].[{{ table_name }}] (
{{~ for col in form_columns ~}}
{{~ if !col.is_identity ~}}
        [{{ col.column_name }}]{{ if !for.last }},{{ end }}
{{~ end ~}}
{{~ end ~}}
    )
    VALUES (
{{~ for col in form_columns ~}}
{{~ if !col.is_identity ~}}
        @{{ col.property_name }}{{ if !for.last }},{{ end }}
{{~ end ~}}
{{~ end ~}}
    );
    SELECT SCOPE_IDENTITY() AS NewId;
END
GO

-- ── sp_Update_{{ table_name }} ────────────────────────────────────────
IF OBJECT_ID('{{ db_schema }}.sp_Update_{{ table_name }}', 'P') IS NOT NULL
    DROP PROCEDURE [{{ db_schema }}].[sp_Update_{{ table_name }}]
