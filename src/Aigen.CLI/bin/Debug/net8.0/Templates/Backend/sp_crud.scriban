-- ─────────────────────────────────────────────────────────────
-- ADD: Crea un nuevo registro
-- Retorna: el registro creado completo
-- ─────────────────────────────────────────────────────────────
CREATE OR ALTER PROCEDURE [{{ sp_schema }}].[{{ sp_prefix }}{{ table_name }}Add]
{{~ for col in form_columns ~}}
{{~ if col.is_identity ~}}{{~ continue ~}}{{~ end ~}}
    @{{ col.column_name }} {{ col.sql_type }}{{ if col.has_max_length }}({{ if col.max_length == -1 }}MAX{{ else }}{{ col.max_length }}{{ end }}){{ end }}{{ if col.column_name == "Estado" }} = 1{{ else if col.is_nullable }} = NULL{{ end }},
{{~ end ~}}
    @auditoria VarChar(MAX) = NULL
AS
BEGIN
    SET NOCOUNT ON;

    INSERT INTO [{{ db_schema }}].[{{ table_name }}] (
{{~ for col in form_columns ~}}
{{~ if col.is_identity ~}}{{~ continue ~}}{{~ end ~}}
        [{{ col.column_name }}]{{ if !for.last }},{{ end }}
{{~ end ~}}
    )
    VALUES (
{{~ for col in form_columns ~}}
{{~ if col.is_identity ~}}{{~ continue ~}}{{~ end ~}}
        @{{ col.column_name }}{{ if !for.last }},{{ end }}
{{~ end ~}}
    );

    -- Retornar el registro creado (compatible con frontend)
    SELECT *
    FROM   [{{ db_schema }}].[{{ table_name }}]
    WHERE  [{{ pk_column_name }}] = SCOPE_IDENTITY();
END
GO

-- ─────────────────────────────────────────────────────────────
-- UPDATE: Actualiza un registro existente
-- Todos los campos son opcionales — solo actualiza los enviados
-- ─────────────────────────────────────────────────────────────
CREATE OR ALTER PROCEDURE [{{ sp_schema }}].[{{ sp_prefix }}{{ table_name }}Update]
    @{{ pk_column_name }} {{ pk_sql_type }},
{{~ for col in form_columns ~}}
{{~ if col.is_identity || col.is_primary_key ~}}{{~ continue ~}}{{~ end ~}}
    @{{ col.column_name }} {{ col.sql_type }}{{ if col.has_max_length }}({{ if col.max_length == -1 }}MAX{{ else }}{{ col.max_length }}{{ end }}){{ end }} = NULL,
{{~ end ~}}
    @auditoria VarChar(MAX) = NULL
AS
BEGIN
    SET NOCOUNT ON;

    UPDATE [{{ db_schema }}].[{{ table_name }}]
    SET
{{~ for col in form_columns ~}}
{{~ if col.is_identity || col.is_primary_key ~}}{{~ continue ~}}{{~ end ~}}
{{~ if col.column_name == "auditoria" || col.column_name == "Auditoria" ~}}
        [{{ col.column_name }}] = @auditoria{{ if !for.last }},{{ end }}
{{~ else ~}}
        [{{ col.column_name }}] = ISNULL(@{{ col.column_name }}, [{{ col.column_name }}]){{ if !for.last }},{{ end }}
{{~ end ~}}
{{~ end ~}}
    WHERE  [{{ pk_column_name }}] = @{{ pk_column_name }}
    {{ if has_estado }}AND [Estado] = 1{{ end }};
END
GO

-- ─────────────────────────────────────────────────────────────
-- DELETE: Eliminación lógica o física con validación dependencias
-- ─────────────────────────────────────────────────────────────
CREATE OR ALTER PROCEDURE [{{ sp_schema }}].[{{ sp_prefix }}{{ table_name }}Delete]
    @{{ pk_column_name }} {{ pk_sql_type }},
    @auditoria VarChar(MAX) = NULL
AS
BEGIN
    SET NOCOUNT ON;

    -- Validar dependencias antes de eliminar
    DECLARE @cantidad   INT = 0;
    DECLARE @esquema    VARCHAR(200);
    DECLARE @tabla      VARCHAR(200);
    DECLARE @mensaje    VARCHAR(1000);
    DECLARE @tDepen TABLE (
        table_schema VARCHAR(255),
        table_name   VARCHAR(255),
        cantidad     INT
    );

    INSERT INTO @tDepen
    EXEC [dbo].[ValidarDependencias] '{{ db_schema }}', '{{ table_name }}', @{{ pk_column_name }};

    SELECT @cantidad = COUNT(0) FROM @tDepen;

    IF @cantidad >= 1
    BEGIN
        SELECT TOP 1 @esquema = table_schema, @tabla = table_name FROM @tDepen;
        SET @mensaje = 'Hay dependencia en la tabla: ' + @esquema + '.' + @tabla;
        RAISERROR(@mensaje, 16, 1);
        RETURN;
    END

    {{ if has_eliminado_column }}
    -- Soft delete via columna Eliminado
    UPDATE [{{ db_schema }}].[{{ table_name }}]
    SET    Eliminado  = 1,
           Auditoria  = @auditoria
    WHERE  [{{ pk_column_name }}] = @{{ pk_column_name }};
    {{ else if has_estado }}
    -- Soft delete via Estado = 0
    UPDATE [{{ db_schema }}].[{{ table_name }}]
    SET    Estado    = 0,
           {{ if has_auditoria_column }}Auditoria = @auditoria{{ end }}
    WHERE  [{{ pk_column_name }}] = @{{ pk_column_name }}
    AND    Estado = 1;
    {{ else }}
    -- Delete físico (tabla sin Estado ni Eliminado)
    DELETE FROM [{{ db_schema }}].[{{ table_name }}]
    WHERE [{{ pk_column_name }}] = @{{ pk_column_name }};
    {{ end }}
END
GO

