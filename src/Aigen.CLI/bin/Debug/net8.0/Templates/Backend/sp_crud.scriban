-- ─────────────────────────────────────────────────────────────
-- GETBYFILTER: Búsqueda filtrada y paginada
-- Mejora vs histórico: sp_executesql para sargability de índices
-- @TamPag: registros por página | @Pag: página (base 1)
-- ─────────────────────────────────────────────────────────────
CREATE OR ALTER PROCEDURE [{{ sp_schema }}].[{{ sp_prefix }}{{ table_name }}GetByFilter]
    -- Filtros por campo (todos opcionales)
{{~ for col in form_columns ~}}
{{~ if col.c_sharp_type == "byte[]" ~}}{{~ continue ~}}{{~ end ~}}
    @{{ col.column_name }} {{ col.sql_type }}{{ if col.has_max_length }}({{ if col.max_length == -1 }}MAX{{ else }}{{ col.max_length }}{{ end }}){{ end }} = NULL,
{{~ end ~}}
    -- Paginación y orden
    @TamPag   INT            = 20,
    @Pag      INT            = 1,
    @OrdenBy  NVARCHAR(128)  = NULL
AS
BEGIN
    SET NOCOUNT ON;

    -- Paginación OFFSET/FETCH (SQL Server 2012+)
    -- Más eficiente que el patrón histórico @pag*@TamPag
    DECLARE @offset   INT = (@Pag - 1) * @TamPag;
    DECLARE @orderCol NVARCHAR(128) = ISNULL(@OrdenBy, '{{ pk_column_name }}');

    -- Construcción dinámica con sp_executesql para sargability
    -- Los parámetros se pasan tipados — el optimizer puede usar índices
    DECLARE @sql    NVARCHAR(MAX);
    DECLARE @where  NVARCHAR(MAX) = N' WHERE 1=1 ';
    DECLARE @params NVARCHAR(MAX);

    {{ if has_estado }}
    SET @where += N' AND [Estado] = 1 ';
    {{ end }}

    -- Filtros dinámicos solo para varchar e int (ignora BLOBs)
{{~ for col in form_columns ~}}
{{~ if col.c_sharp_type == "byte[]" || col.is_primary_key ~}}{{~ continue ~}}{{~ end ~}}
{{~ if col.c_sharp_type == "string" ~}}
    IF @{{ col.column_name }} IS NOT NULL
        SET @where += N' AND [{{ col.column_name }}] LIKE ''%'' + @{{ col.column_name }} + ''%'' ';
{{~ else if col.c_sharp_type == "int" || col.c_sharp_type == "bool" ~}}
    IF @{{ col.column_name }} IS NOT NULL
        SET @where += N' AND [{{ col.column_name }}] = @{{ col.column_name }} ';
{{~ end ~}}
{{~ end ~}}

    SET @sql = N'
        SELECT {{ for col in list_columns }}{{ if !col.is_blob }}[{{ col.column_name }}]{{ if !for.last }}, {{ end }}{{ end }}{{ end }}
        FROM   [{{ db_schema }}].[{{ table_name }}]'
        + @where
        + N' ORDER BY [' + @orderCol + N'] DESC
        OFFSET @offset ROWS FETCH NEXT @tamPag ROWS ONLY;

        SELECT COUNT(0)
        FROM   [{{ db_schema }}].[{{ table_name }}]'
        + @where;

    SET @params = N'
{{~ for col in form_columns ~}}
{{~ if col.c_sharp_type == "byte[]" ~}}{{~ continue ~}}{{~ end ~}}
        @{{ col.column_name }} {{ col.sql_type }}{{ if col.has_max_length }}({{ if col.max_length == -1 }}MAX{{ else }}{{ col.max_length }}{{ end }}){{ end }},
{{~ end ~}}
        @offset INT, @tamPag INT';

    EXEC sp_executesql @sql, @params,
{{~ for col in form_columns ~}}
{{~ if col.c_sharp_type == "byte[]" ~}}{{~ continue ~}}{{~ end ~}}
        @{{ col.column_name }} = @{{ col.column_name }},
{{~ end ~}}
        @offset = @offset, @tamPag = @TamPag;
END
GO

{{ if has_estado }}
-- -----------------------------------------------------------------
-- TOGGLEESTADO: Activa/desactiva un registro (Estado = ~Estado)
-- -----------------------------------------------------------------
CREATE OR ALTER PROCEDURE [{{ sp_schema }}].[{{ sp_prefix }}{{ table_name }}ToggleEstado]
    @{{ pk_column_name }} {{ pk_sql_type }},
    @auditoria VarChar(MAX) = NULL
AS
BEGIN
    SET NOCOUNT ON;

    UPDATE [{{ db_schema }}].[{{ table_name }}]
    SET    [{{ estado_property_name }}] = CASE WHEN [{{ estado_property_name }}] = 1 THEN 0 ELSE 1 END
           {{ if has_auditoria_column }}, Auditoria = @auditoria{{ end }}
    WHERE  [{{ pk_column_name }}] = @{{ pk_column_name }};

    -- Retornar el estado resultante
    SELECT [{{ pk_column_name }}], [{{ estado_property_name }}]
    FROM   [{{ db_schema }}].[{{ table_name }}]
    WHERE  [{{ pk_column_name }}] = @{{ pk_column_name }};
END
GO
{{ end }}