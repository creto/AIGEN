GO

-- TR_RolPrivilegio
IF NOT EXISTS (SELECT 1 FROM INFORMATION_SCHEMA.TABLES
               WHERE TABLE_SCHEMA = 'Seguridad' AND TABLE_NAME = 'TR_RolPrivilegio')
BEGIN
    CREATE TABLE [Seguridad].[TR_RolPrivilegio](
        [AspNetRoles]      NVARCHAR(256) NOT NULL,
        [Id_TP_Privilegio] INT           NOT NULL,
        [Estado]           BIT           NOT NULL DEFAULT(1),
        [auditoria]        VARCHAR(MAX)  NULL,
        CONSTRAINT [PK_TR_RolPrivilegio] PRIMARY KEY CLUSTERED ([Id_TP_Privilegio] ASC, [AspNetRoles] ASC)
    );
    PRINT 'Tabla Seguridad.TR_RolPrivilegio creada';
END
GO

-- ============================================================
-- SEED: un item de menu por controller generado por AIGEN
-- MERGE garantiza idempotencia
-- ============================================================
{{ $orden = 1 }}
{{ for table in all_tables_script }}
{{ if table.has_full_crud }}
MERGE [Seguridad].[TP_Menu] AS target
USING (SELECT '{{ table.controller_name }}' AS Controlador, 'Index' AS Accion) AS source
ON  target.[Controlador] = source.Controlador
AND target.[Accion]      = source.Accion
WHEN NOT MATCHED THEN
    INSERT ([Nombre],[Descripcion],[Controlador],[Accion],[GrupoEsquema],
            [Link],[Orden],[OrdenPadre],[Padre],[Icono],[Visible],[RequiereAutenticacion],[EstadoMenu],[Estado])
    VALUES (
        '{{ table.entity_name_plural }}',
        'Gestion de {{ table.entity_name_plural }}',
        '{{ table.controller_name }}',
        'Index',
        '{{ project_name }}',
        '/{{ table.kebab_name_plural }}',
        {{ $orden }},
        NULL,
        NULL,
        'pi pi-table',
        1, 1, 1, 1
    );
{{ $orden = $orden + 1 }}
{{ end }}
{{ end }}
GO

-- Rol Admin tiene acceso a todos los menus
INSERT INTO [Seguridad].[TR_MenuRol] ([Id_TP_Menu], [AspNetRoles], [Estado])
SELECT m.[Id], 'Admin', 1
FROM   [Seguridad].[TP_Menu] m
WHERE  NOT EXISTS (
    SELECT 1 FROM [Seguridad].[TR_MenuRol] r
    WHERE r.[Id_TP_Menu] = m.[Id] AND r.[AspNetRoles] = 'Admin'
);

-- Rol Admin tiene todos los privilegios
INSERT INTO [Seguridad].[TR_RolPrivilegio] ([AspNetRoles], [Id_TP_Privilegio], [Estado])
SELECT 'Admin', p.[Id], 1
FROM   [Seguridad].[TP_Privilegio] p
WHERE  NOT EXISTS (
    SELECT 1 FROM [Seguridad].[TR_RolPrivilegio] r
    WHERE r.[AspNetRoles] = 'Admin' AND r.[Id_TP_Privilegio] = p.[Id]
);
GO

PRINT 'Menu seed completado — {{ project_name }}';
GO