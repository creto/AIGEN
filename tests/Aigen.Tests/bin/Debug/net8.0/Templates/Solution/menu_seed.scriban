-- ============================================================
-- AIGEN — Menu Seed para {{ project_name }}
-- Generado : {{ now }}
-- Esquema  : Seguridad (patron historico TiGlobal SAS — mejorado)
-- Idempotente: puede ejecutarse multiples veces sin duplicar
-- ============================================================

-- Schema
IF NOT EXISTS (SELECT 1 FROM sys.schemas WHERE name = 'Seguridad')
    EXEC('CREATE SCHEMA [Seguridad]');
GO

-- TP_Menu
IF NOT EXISTS (SELECT 1 FROM INFORMATION_SCHEMA.TABLES
               WHERE TABLE_SCHEMA = 'Seguridad' AND TABLE_NAME = 'TP_Menu')
BEGIN
    CREATE TABLE [Seguridad].[TP_Menu](
        [Id]                    INT          IDENTITY(1,1) NOT NULL,
        [Nombre]                VARCHAR(160) NOT NULL,
        [Descripcion]           VARCHAR(300) NULL,
        [Controlador]           VARCHAR(160) NOT NULL,
        [Accion]                VARCHAR(160) NOT NULL DEFAULT('Index'),
        [GrupoEsquema]          VARCHAR(160) NOT NULL,
        [Link]                  VARCHAR(160) NOT NULL,
        [Orden]                 INT          NULL,
        [OrdenPadre]            INT          NULL,
        [Padre]                 INT          NULL,
        [Icono]                 VARCHAR(80)  NULL,
        [Badge]                 VARCHAR(50)  NULL,
        [Visible]               BIT          NOT NULL DEFAULT(1),
        [RequiereAutenticacion] BIT          NOT NULL DEFAULT(1),
        [EstadoMenu]            BIT          NOT NULL DEFAULT(1),
        [Estado]                BIT          NOT NULL DEFAULT(1),
        [auditoria]             VARCHAR(MAX) NULL,
        CONSTRAINT [PK_TP_Menu] PRIMARY KEY CLUSTERED ([Id] ASC)
    );
    PRINT 'Tabla Seguridad.TP_Menu creada';
END
ELSE
BEGIN
    -- Agregar columnas nuevas si no existen (migracion incremental)
    IF NOT EXISTS (SELECT 1 FROM INFORMATION_SCHEMA.COLUMNS
                   WHERE TABLE_SCHEMA='Seguridad' AND TABLE_NAME='TP_Menu' AND COLUMN_NAME='Descripcion')
        ALTER TABLE [Seguridad].[TP_Menu] ADD [Descripcion] VARCHAR(300) NULL;

    IF NOT EXISTS (SELECT 1 FROM INFORMATION_SCHEMA.COLUMNS
                   WHERE TABLE_SCHEMA='Seguridad' AND TABLE_NAME='TP_Menu' AND COLUMN_NAME='Badge')
        ALTER TABLE [Seguridad].[TP_Menu] ADD [Badge] VARCHAR(50) NULL;

    IF NOT EXISTS (SELECT 1 FROM INFORMATION_SCHEMA.COLUMNS
                   WHERE TABLE_SCHEMA='Seguridad' AND TABLE_NAME='TP_Menu' AND COLUMN_NAME='Visible')
        ALTER TABLE [Seguridad].[TP_Menu] ADD [Visible] BIT NOT NULL DEFAULT(1);

    IF NOT EXISTS (SELECT 1 FROM INFORMATION_SCHEMA.COLUMNS
                   WHERE TABLE_SCHEMA='Seguridad' AND TABLE_NAME='TP_Menu' AND COLUMN_NAME='RequiereAutenticacion')
        ALTER TABLE [Seguridad].[TP_Menu] ADD [RequiereAutenticacion] BIT NOT NULL DEFAULT(1);

    PRINT 'Tabla Seguridad.TP_Menu actualizada con columnas nuevas';
END
GO

-- TR_MenuRol
IF NOT EXISTS (SELECT 1 FROM INFORMATION_SCHEMA.TABLES
               WHERE TABLE_SCHEMA = 'Seguridad' AND TABLE_NAME = 'TR_MenuRol')
BEGIN
    CREATE TABLE [Seguridad].[TR_MenuRol](
        [Id_TP_Menu]  INT           NOT NULL,
        [AspNetRoles] NVARCHAR(256) NOT NULL,
        [Estado]      BIT           NOT NULL DEFAULT(1),
        [auditoria]   VARCHAR(MAX)  NULL,
        CONSTRAINT [PK_TR_MenuRol] PRIMARY KEY CLUSTERED ([Id_TP_Menu] ASC, [AspNetRoles] ASC)
    );
    PRINT 'Tabla Seguridad.TR_MenuRol creada';
END
GO

