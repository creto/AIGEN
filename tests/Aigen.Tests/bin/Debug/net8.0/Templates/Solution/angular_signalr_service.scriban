// <auto-generated by AIGEN — {{ project_name }} />
import { Injectable, OnDestroy }        from '@angular/core';
import { HubConnection, HubConnectionBuilder, LogLevel } from '@microsoft/signalr';
import { Subject, BehaviorSubject }     from 'rxjs';
import { environment }                  from '../../environments/environment';
import { AuthService }                  from './auth.service';

export interface Notification {
  type:      string;
  message:   string;
  data?:     any;
  timestamp: string;
}

@Injectable({ providedIn: 'root' })
export class SignalRService implements OnDestroy {
  private hub!: HubConnection;

  // Observable de notificaciones — suscribirse en componentes
  private _notification$ = new Subject<Notification>();
  public  notification$  = this._notification$.asObservable();

  // Estado de conexion
  private _connected$ = new BehaviorSubject<boolean>(false);
  public  connected$  = this._connected$.asObservable();

  constructor(private authService: AuthService) {}

  /** Iniciar conexion al hub — llamar tras login exitoso */
  async startAsync(): Promise<void> {
    if (this.hub?.state === 'Connected') return;

    this.hub = new HubConnectionBuilder()
      .withUrl(`${environment.apiUrl}/hubs/notifications`, {
        accessTokenFactory: () => this.authService.getToken() ?? ''
      })
      .withAutomaticReconnect([0, 2000, 5000, 10000, 30000])
      .configureLogging(LogLevel.Warning)
      .build();

    // Recibir notificaciones del servidor
    this.hub.on('ReceiveNotification', (notification: Notification) => {
      this._notification$.next(notification);
    });

    // Eventos de conexion
    this.hub.onreconnecting(() => this._connected$.next(false));
    this.hub.onreconnected(() => this._connected$.next(true));
    this.hub.onclose(() => this._connected$.next(false));

    try {
      await this.hub.start();
      this._connected$.next(true);
    } catch (err) {
      console.error('SignalR connection error:', err);
      this._connected$.next(false);
    }
  }

  /** Detener conexion — llamar al logout */
  async stopAsync(): Promise<void> {
    if (this.hub) {
      await this.hub.stop();
      this._connected$.next(false);
    }
  }

  /** Enviar notificacion a un usuario especifico */
  async notifyUser(username: string, type: string, message: string, data?: any): Promise<void> {
    await this.hub?.invoke('SendToUser', username, type, message, data);
  }

  /** Enviar notificacion a un rol */
  async notifyRole(role: string, type: string, message: string, data?: any): Promise<void> {
    await this.hub?.invoke('SendToRole', role, type, message, data);
  }

  ngOnDestroy(): void {
    this.stopAsync();
  }
}