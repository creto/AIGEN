// <auto-generated by AIGEN — {{ project_name }} />
#nullable enable
using Microsoft.AspNetCore.Authorization;
using Microsoft.AspNetCore.Mvc;
using Microsoft.Data.SqlClient;
using Dapper;
using System.Data;

namespace {{ root_namespace }}.API.Controllers;

/// <summary>
/// Retorna el arbol de menu filtrado por los roles del usuario autenticado.
/// </summary>
[ApiController]
[Route("api/[controller]")]
[Authorize]
public class MenuController : ControllerBase
{
    private readonly IDbConnection _db;

    public MenuController(IDbConnection db) => _db = db;

    /// <summary>
    /// GET /api/menu — retorna arbol jerarquico de menu segun roles del JWT.
    /// </summary>
    [HttpGet]
    public async Task<IActionResult> GetMenu()
    {
        // Extraer roles del JWT
        var roles = User.Claims
            .Where(c => c.Type == System.Security.Claims.ClaimTypes.Role
                     || c.Type == "roles"
                     || c.Type == "role")
            .Select(c => c.Value)
            .Distinct()
            .ToList();

        if (!roles.Any())
            return Ok(new List<MenuItemDto>());

        // Construir IN clause con parametros Dapper
        var roleParams = string.Join(",", roles.Select((_, i) => $"@r{i}"));
        var dynParams  = new DynamicParameters();
        for (int i = 0; i < roles.Count; i++)
            dynParams.Add($"r{i}", roles[i]);

        var sql = $@"
            SELECT DISTINCT
                m.[Id],
                m.[Nombre],
                m.[Descripcion],
                m.[Link],
                m.[Icono],
                m.[Badge],
                m.[Orden],
                m.[OrdenPadre],
                m.[Padre],
                m.[Visible],
                m.[RequiereAutenticacion]
            FROM  [Seguridad].[TP_Menu]    m
            JOIN  [Seguridad].[TR_MenuRol] r ON r.[Id_TP_Menu] = m.[Id]
            WHERE m.[EstadoMenu] = 1
              AND m.[Estado]     = 1
              AND m.[Visible]    = 1
              AND r.[AspNetRoles] IN ({roleParams})
              AND r.[Estado]     = 1
            ORDER BY m.[OrdenPadre], m.[Orden]";

        var items = (await _db.QueryAsync<MenuItemDto>(sql, dynParams)).ToList();

        // Armar arbol jerarquico
        var tree = BuildTree(items, null);
        return Ok(tree);
    }

    /// <summary>
    /// GET /api/menu/privilegios — retorna privilegios del usuario por menu.
    /// </summary>
    [HttpGet("privilegios")]
    public async Task<IActionResult> GetPrivilegios()
    {
        var roles = User.Claims
            .Where(c => c.Type == System.Security.Claims.ClaimTypes.Role
                     || c.Type == "roles"
                     || c.Type == "role")
            .Select(c => c.Value)
            .Distinct()
            .ToList();

        if (!roles.Any())
            return Ok(new List<object>());

        var roleParams = string.Join(",", roles.Select((_, i) => $"@r{i}"));
        var dynParams  = new DynamicParameters();
        for (int i = 0; i < roles.Count; i++)
            dynParams.Add($"r{i}", roles[i]);

        var sql = $@"
            SELECT DISTINCT p.[Nombre] as Privilegio
            FROM  [Seguridad].[TR_RolPrivilegio] rp
            JOIN  [Seguridad].[TP_Privilegio]    p  ON p.[Id] = rp.[Id_TP_Privilegio]
            WHERE rp.[AspNetRoles] IN ({roleParams})
              AND rp.[Estado] = 1
              AND p.[Estado]  = 1";

        var privilegios = await _db.QueryAsync<string>(sql, dynParams);
        return Ok(privilegios);
    }

    private static List<MenuItemDto> BuildTree(List<MenuItemDto> items, int? parentId)
    {
        return items
            .Where(i => i.Padre == parentId)
            .OrderBy(i => i.Orden)
            .Select(i => {
                i.Children = BuildTree(items, i.Id);
                return i;
            })
            .ToList();
    }
}

public class MenuItemDto
{
    public int     Id                    { get; set; }
    public string  Nombre                { get; set; } = string.Empty;
    public string? Descripcion           { get; set; }
    public string  Link                  { get; set; } = string.Empty;
    public string? Icono                 { get; set; }
    public string? Badge                 { get; set; }
    public int?    Orden                 { get; set; }
    public int?    OrdenPadre            { get; set; }
    public int?    Padre                 { get; set; }
    public bool    Visible               { get; set; }
    public bool    RequiereAutenticacion { get; set; }
    public List<MenuItemDto> Children    { get; set; } = new();
}